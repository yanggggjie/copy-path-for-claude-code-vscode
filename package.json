{
  "name": "copy-path-for-agent",
  "displayName": "Copy Path for Agent (VS Code)",
  "description": "VS Code extension that copies file/folder references in agent @-mention format (@path/to/file#L42-68). Forked from Copy Path for Claude Code by Teppasit W.",
  "version": "1.1.5",
  "publisher": "yanggggjie",
  "author": {
    "name": "yanggggjie"
  },
  "contributors": [
    {
      "name": "Teppasit",
      "email": "teppasit.w@gmail.com"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanggggjie/copy-path-for-claude-code-vscode.git"
  },
  "homepage": "https://github.com/yanggggjie/copy-path-for-claude-code-vscode#readme",
  "bugs": {
    "url": "https://github.com/yanggggjie/copy-path-for-claude-code-vscode/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "agent",
    "claude",
    "claude-code",
    "copy-path",
    "ai",
    "reference"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#D77655",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyPathForClaudeCode.copy",
        "title": "Copy Path for Claude Code"
      },
      {
        "command": "copyPathForClaudeCode.copyFromExplorer",
        "title": "Copy Path for Claude Code (Explorer)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copyPathForClaudeCode.copy",
          "group": "9_cutcopypaste@50"
        }
      ],
      "explorer/context": [
        {
          "command": "copyPathForClaudeCode.copy",
          "group": "6_copypath@50"
        }
      ],
      "commandPalette": [
        {
          "command": "copyPathForClaudeCode.copyFromExplorer",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "copyPathForClaudeCode.copy",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "copyPathForClaudeCode.copyFromExplorer",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "filesExplorerFocus"
      },
      {
        "command": "copyPathForClaudeCode.copy",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "!editorTextFocus && !filesExplorerFocus && !terminalFocus"
      }
    ],
    "configuration": {
      "title": "Copy Path for Claude Code",
      "properties": {
        "copyPathForClaudeCode.appendTrailingSpace": {
          "type": "boolean",
          "default": true,
          "description": "Append a trailing space after the copied reference"
        },
        "copyPathForClaudeCode.multipleReferencesSeparator": {
          "type": "string",
          "enum": [
            "Space",
            "Newline"
          ],
          "default": "Space",
          "description": "Separator between multiple references"
        },
        "copyPathForClaudeCode.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show notification after copying"
        },
        "copyPathForClaudeCode.copyCurrentLineWhenNoSelection": {
          "type": "boolean",
          "default": true,
          "description": "When no text is selected (single cursor), include the cursor's line number in the copied reference"
        },
        "copyPathForClaudeCode.useAbsolutePath": {
          "type": "boolean",
          "default": true,
          "description": "Copy the full absolute filesystem path instead of the workspace-relative path"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/suite/index.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "mocha": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
